## 获取层级名称的索引
func get_layer_index(layer_name: String) -> int:
	return zmap_layer.find(layer_name)

## 判断 layer_a 是否在 layer_b 前面（先渲染）
func is_front_of(layer_a: String, layer_b: String) -> bool:
	return get_layer_index(layer_a) < get_layer_index(layer_b)
